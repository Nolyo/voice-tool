# Default: text files use LF in working tree, regardless of core.autocrlf
* text=auto eol=lf

# Windows-specific scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.icns  binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.wav   binary
*.mp3   binary
*.ogg   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.exe   binary
*.dll   binary
*.so    binary
*.dylib binary
