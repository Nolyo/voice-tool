{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lexena",
  "version": "3.0.0-beta.4",
  "identifier": "com.nolyo.lexena",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lexena",
        "width": 1000,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 600,
        "maximized": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "$APP/**",
          "$RESOURCE/*",
          "$APPDATA/com.nolyo.lexena/profiles/*/recordings/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "fr-FR"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["lexena"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MThCMjZDNzlBMjBDNDAKUldSQURLSjViTElZTlY1cWt4bUhvVnFra01heHpaMmFJOUpYMDgrd3NrcjlnVE5aT0Q1QURScm4K",
      "endpoints": [
        "https://github.com/Nolyo/lexena/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}